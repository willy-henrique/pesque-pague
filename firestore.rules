rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Leitura pública (portal do cliente) ────────────────
    match /piques/{id}      { allow read: if true; }
    match /categorias/{id}  { allow read: if true; }
    match /produtos/{id}    { allow read: if true; }
    match /config/{id}      { allow read: if true; }
    match /promocoes/{id}   { allow read: if true; allow write: if request.auth != null; }

    // ── Pedidos ─────────────────────────────────────────────
    match /pedidos/{id} {
      allow create: if true;             // cliente cria sem login
      allow read:   if true;             // cliente lê a própria comanda
      allow update: if request.auth != null; // só gerente avança status
      allow delete: if request.auth != null;
    }

    // ── Admin (tudo exige login) ─────────────────────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
